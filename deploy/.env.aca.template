# Copy to deploy/.env.aca and fill in. This file is git-ignored.
#
# IMPORTANT (cross-tenant model):
#   - Tenant 1 = the Azure subscription that hosts the Container App (compute only).
#   - Tenant 2 = the Microsoft 365 / Agent 365 tenant where the agent is registered,
#     emits telemetry, and lives in Teams.
#   EVERY identity value below comes from the TENANT 2 Agent 365 registration,
#   even though the container runs in tenant 1.

# ---- Azure (tenant 1) — where the Container App is deployed ----------------
SUBSCRIPTION_ID=<<TENANT1_AZURE_SUBSCRIPTION_ID>>
RESOURCE_GROUP=rg-agent365-sample
LOCATION=eastus
ACR_NAME=<<GLOBALLY_UNIQUE_ACR_NAME>>
CONTAINERAPP_ENV=cae-agent365-sample
APP_NAME=agentframework-sample
IMAGE_TAG=v1

# ---- Agent identity (tenant 2) — inbound JWT validation -------------------
CLIENT_ID=<<TENANT2_AGENT_APP_ID>>
TENANT_ID=<<TENANT2_TENANT_ID>>
CLIENT_SECRET=<<TENANT2_AGENT_CLIENT_SECRET>>

# ---- Agentic auth service connection (tenant 2) — telemetry + Graph -------
CONN_CLIENTID=<<TENANT2_SERVICE_CONNECTION_CLIENT_ID>>
CONN_CLIENTSECRET=<<TENANT2_SERVICE_CONNECTION_CLIENT_SECRET>>
CONN_TENANTID=<<TENANT2_TENANT_ID>>
CONN_SCOPES=https://graph.microsoft.com/.default

# ---- LLM credentials -------------------------------------------------------
# Azure OpenAI (preferred) ...
AZURE_OPENAI_API_KEY=<<AZURE_OPENAI_API_KEY>>
AZURE_OPENAI_ENDPOINT=<<AZURE_OPENAI_ENDPOINT>>
AZURE_OPENAI_DEPLOYMENT=<<AZURE_OPENAI_DEPLOYMENT>>
AZURE_OPENAI_API_VERSION=2024-10-21
# ... or OpenAI (leave Azure values blank if using this)
OPENAI_API_KEY=
OPENAI_MODEL=

# ---- Observability ---------------------------------------------------------
OBSERVABILITY_SERVICE_NAME=agent-framework-sample
OBSERVABILITY_SERVICE_NAMESPACE=agent-framework.samples
