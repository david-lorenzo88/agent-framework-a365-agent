# Copy to deploy/.env.aca and fill in the <<PLACEHOLDERS>>. This file is git-ignored.
#
# Cross-tenant model:
#   - Tenant 1 = the Azure subscription that hosts the Container App (compute only).
#   - Tenant 2 = the Microsoft 365 / Agent 365 tenant where the agent is registered,
#     emits telemetry, and lives in Teams.
#   Every identity/agent value below comes from the TENANT 2 Agent 365 registration
#   (`a365 setup blueprint` / `a365 publish`), even though the container runs in tenant 1.

# ---- Azure (tenant 1) — where the Container App is deployed ----------------
SUBSCRIPTION_ID=<<TENANT1_AZURE_SUBSCRIPTION_ID>>
RESOURCE_GROUP=rg-agent365-sample
LOCATION=eastus
ACR_NAME=<<GLOBALLY_UNIQUE_ACR_NAME>>
CONTAINERAPP_ENV=cae-agent365-sample
APP_NAME=agentframework-a365-agent
IMAGE_TAG=v1

# ---- Agent identity (tenant 2) — inbound JWT validation -------------------
# Blueprint appId + client secret from `a365 setup blueprint`.
CLIENT_ID=<<TENANT2_BLUEPRINT_APP_ID>>
TENANT_ID=<<TENANT2_TENANT_ID>>
CLIENT_SECRET=<<TENANT2_BLUEPRINT_CLIENT_SECRET>>

# ---- Agentic auth service connection (tenant 2) — telemetry + Graph -------
# Single-identity model: same blueprint credentials as above.
CONN_CLIENTID=<<TENANT2_BLUEPRINT_APP_ID>>
CONN_CLIENTSECRET=<<TENANT2_BLUEPRINT_CLIENT_SECRET>>
CONN_TENANTID=<<TENANT2_TENANT_ID>>
CONN_SCOPES=

# ---- Telemetry auth: SDK FIC (app-token) resolver -------------------------
# Instance + agentic-user ids of the APPROVED agent. After `a365 publish` and
# admin approval, read them from the container's first-turn log line
# ("tenant_id=..., agent_id=...") or the Agent 365 admin center.
A365_AGENT_APP_INSTANCE_ID=<<AGENT_INSTANCE_APP_ID>>
A365_AGENTIC_USER_ID=<<AGENTIC_USER_OBJECT_ID>>
# FIC mints a delegated (user) OtelWrite token -> pairs with the non-S2S endpoint.
A365_USE_S2S_ENDPOINT=false

# ---- LLM (Azure OpenAI — the agent uses this exclusively) ------------------
AZURE_OPENAI_API_KEY=<<AZURE_OPENAI_API_KEY>>
AZURE_OPENAI_ENDPOINT=<<AZURE_OPENAI_ENDPOINT>>
AZURE_OPENAI_DEPLOYMENT=<<AZURE_OPENAI_DEPLOYMENT>>
# Agent Framework's OpenAIChatClient targets the Azure /openai/v1/ surface,
# which requires api-version=preview.
AZURE_OPENAI_API_VERSION=preview

# ---- Observability ---------------------------------------------------------
OBSERVABILITY_SERVICE_NAME=agent-framework-a365-agent
OBSERVABILITY_SERVICE_NAMESPACE=agent-framework.samples
